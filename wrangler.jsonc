{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "icomics",
  "compatibility_date": "2026-04-28",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "main": ".open-next/worker.js"
}
