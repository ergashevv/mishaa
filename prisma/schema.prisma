generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  username     String   @unique
  password     String?
  email        String?  @unique
  avatar       String?
  authProvider String   @default("local")
  authProviderId String? @unique
  createdAt    DateTime @default(now())
  stories      Story[]
  characters   Character[]
  readingProgress ReadingProgress[]
}

model Story {
  id            String   @id @default(cuid())
  title         String?
  globalContext String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  content       Json?    // Universal Studio State (Pages, Drafts, Settings)
  status        String   @default("draft")
  frames        Frame[]
}

model Frame {
  id          String   @id @default(cuid())
  storyId     String
  prompt      String
  imageUrl    String?
  shotType    String   @default("medium")
  characters  String[] @default([])
  dialogue    String?
  soundEffect String?
  position    Int
  createdAt   DateTime @default(now())
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Character {
  id          String   @id @default(cuid())
  name        String
  role        String
  description String
  imageUrl    String
  createdAt   DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ReadingProgress {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source          String
  comicId         String
  comicTitle      String?
  comicCoverUrl   String?
  chapterId       String?
  chapterTitle    String?
  currentPage     Int      @default(0)
  totalPages      Int      @default(0)
  chapterIndex    Int      @default(0)
  chapterCount    Int      @default(0)
  progressPercent Int      @default(0)
  progressStatus  String   @default("started")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, source, comicId])
  @@index([userId, updatedAt])
  @@index([source, comicId])
}

model TelegramPostLog {
  id                String   @id @default(cuid())
  slotKey           String   @unique
  slotName          String
  comicId           String
  comicSource       String
  comicTitle        String
  comicUrl          String
  comicRating       String?
  telegramMessageId Int?
  status            String   @default("sending")
  error             String?
  sentAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([slotName])
  @@index([status])
  @@index([sentAt])
}

/** Single-row flag: while set in the future, slot crons skip and queue cron drives 2h posts. */
model TelegramCampaignState {
  id              String    @id @default("singleton")
  intensiveEndsAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TelegramScheduledPost {
  id                String    @id @default(cuid())
  scheduledAt       DateTime
  status            String    @default("pending")
  orderIndex        Int
  featureLabel      String
  comicPayload      Json
  error             String?
  sentAt            DateTime?
  telegramMessageId Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([scheduledAt])
}
